      "severeWarning": {
        "40":  { "$value": "#D83B01", "$type": "color" },
        "60":  { "$value": "#EA6233", "$type": "color" },
        "100": { "$value": "#FEEEE6", "$type": "color" }
      }
    }
  },
  "font": {
    "$description": "Type primitives. Semantic ramp (body1, subtitle1, …) is in semantic.tokens.json.",
    "family": {
      "base":     { "$value": "'Segoe UI Variable', 'Segoe UI', system-ui, -apple-system, BlinkMacSystemFont, sans-serif", "$type": "fontFamily" },
      "monospace":{ "$value": "Consolas, 'Cascadia Mono', monospace", "$type": "fontFamily" },
      "numeric":  { "$value": "'Segoe UI Variable Display', 'Segoe UI', system-ui, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" }
    },
    "size": {
      "100": { "$value": "10px", "$type": "dimension" },
      "200": { "$value": "12px", "$type": "dimension" },
      "300": { "$value": "14px", "$type": "dimension" },
      "400": { "$value": "16px", "$type": "dimension" },
      "500": { "$value": "20px", "$type": "dimension" },
      "600": { "$value": "24px", "$type": "dimension" },
      "700": { "$value": "28px", "$type": "dimension" },
      "800": { "$value": "32px", "$type": "dimension" },
      "900": { "$value": "40px", "$type": "dimension" },
      "1000":{ "$value": "68px", "$type": "dimension" }
    },
    "lineHeight": {
      "100": { "$value": "14px", "$type": "dimension" },
      "200": { "$value": "16px", "$type": "dimension" },
      "300": { "$value": "20px", "$type": "dimension" },
      "400": { "$value": "22px", "$type": "dimension" },
      "500": { "$value": "28px", "$type": "dimension" },
      "600": { "$value": "32px", "$type": "dimension" },
      "700": { "$value": "36px", "$type": "dimension" },
      "800": { "$value": "40px", "$type": "dimension" },
      "900": { "$value": "52px", "$type": "dimension" },
      "1000":{ "$value": "92px", "$type": "dimension" }
    }
  },
  "space": {
    "$description": "Fluent 2 spacing scale. Use semantic tokens (e.g. spacing.field.gap) in components; never bind raw space directly.",
    "none":  { "$value": "0px",  "$type": "dimension" },
    "xxs":   { "$value": "2px",  "$type": "dimension" },
    "xs":    { "$value": "4px",  "$type": "dimension" },
    "snudge":{ "$value": "6px",  "$type": "dimension" },
    "s":     { "$value": "8px",  "$type": "dimension" },
    "mnudge":{ "$value": "10px", "$type": "dimension" },
    "m":     { "$value": "12px", "$type": "dimension" },
    "l":     { "$value": "16px", "$type": "dimension" },
    "xl":    { "$value": "20px", "$type": "dimension" },
    "xxl":   { "$value": "24px", "$type": "dimension" },
    "xxxl":  { "$value": "32px", "$type": "dimension" }
  },
  "radius": {
    "$description": "Border-radius primitives. Fluent 2 Web.",
    "none":     { "$value": "0px",  "$type": "dimension" },
    "small":    { "$value": "2px",  "$type": "dimension" },
    "medium":   { "$value": "4px",  "$type": "dimension" },
    "large":    { "$value": "6px",  "$type": "dimension" },
    "xlarge":   { "$value": "8px",  "$type": "dimension" },
    "circular": { "$value": "9999px", "$type": "dimension" }
  },
  "stroke": {
    "$description": "Stroke widths used for borders, dividers, and focus rings.",
    "thinner": { "$value": "0.5px", "$type": "dimension" },
    "thin":    { "$value": "1px",   "$type": "dimension" },
    "thick":   { "$value": "2px",   "$type": "dimension" },
    "thicker": { "$value": "3px",   "$type": "dimension" },
    "thickest":{ "$value": "4px",   "$type": "dimension" }
  },
  "elevation": {
    "$description": "Fluent 2 elevation. Pair with light/dark via semantic.surface tokens.",
    "shadow2":  { "$value": "0px 1px 2px rgba(0,0,0,0.14), 0px 0px 2px rgba(0,0,0,0.12)",  "$type": "shadow" },
    "shadow4":  { "$value": "0px 2px 4px rgba(0,0,0,0.14), 0px 0px 2px rgba(0,0,0,0.12)",  "$type": "shadow" },
    "shadow8":  { "$value": "0px 4px 8px rgba(0,0,0,0.14), 0px 0px 2px rgba(0,0,0,0.12)",  "$type": "shadow" },
    "shadow16": { "$value": "0px 8px 16px rgba(0,0,0,0.14), 0px 0px 2px rgba(0,0,0,0.12)", "$type": "shadow" },
    "shadow28": { "$value": "0px 14px 28px rgba(0,0,0,0.24), 0px 0px 8px rgba(0,0,0,0.20)","$type": "shadow" },
    "shadow64": { "$value": "0px 32px 64px rgba(0,0,0,0.24), 0px 0px 8px rgba(0,0,0,0.20)","$type": "shadow" }
  },
  "duration": {
    "$description": "Motion durations.",
    "ultraFast": { "$value": "50ms",  "$type": "duration" },
    "faster":    { "$value": "100ms", "$type": "duration" },
    "fast":      { "$value": "150ms", "$type": "duration" },
    "normal":    { "$value": "200ms", "$type": "duration" },
    "slow":      { "$value": "300ms", "$type": "duration" },
    "slower":    { "$value": "400ms", "$type": "duration" },
    "ultraSlow": { "$value": "500ms", "$type": "duration" }
  },
  "easing": {
    "$description": "Motion easings.",
    "accelerate":   { "$value": "cubic-bezier(0.7, 0.0, 1.0, 0.5)", "$type": "cubicBezier" },
    "decelerate":   { "$value": "cubic-bezier(0.1, 0.9, 0.2, 1.0)", "$type": "cubicBezier" },
    "easyEase":     { "$value": "cubic-bezier(0.33, 0.0, 0.67, 1.0)","$type": "cubicBezier" },
    "linear":       { "$value": "cubic-bezier(0, 0, 1, 1)",          "$type": "cubicBezier" }
  }
}
