        "10":  { "$value": "#052505", "$type": "color" },
        "20":  { "$value": "#094509", "$type": "color" },
        "40":  { "$value": "#107C10", "$type": "color" },
        "60":  { "$value": "#54B054", "$type": "color" },
        "80":  { "$value": "#9FD89F", "$type": "color" },
        "100": { "$value": "#DFF6DD", "$type": "color" }
      },
      "warning": {
        "10":  { "$value": "#271300", "$type": "color" },
        "20":  { "$value": "#4D2A00", "$type": "color" },
        "40":  { "$value": "#7A4900", "$type": "color" },
        "60":  { "$value": "#BC4B09", "$type": "color" },
        "80":  { "$value": "#FCE100", "$type": "color" },
        "100": { "$value": "#FFF8C4", "$type": "color" }
