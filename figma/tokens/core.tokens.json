      "white":   { "$value": "#FFFFFF", "$type": "color" },
      "black":   { "$value": "#000000", "$type": "color" },
      "transparent": { "$value": "#00000000", "$type": "color" }
    },
    "brand": {
      "$description": "Fluent 2 brand ramp. Default placeholder = Smartbox red (#E2231A area). Replace with the final brand swatch from marketing; the semantic tokens already reference the named stops below so a swap takes effect everywhere.",
      "smartboxRed": {
        "10":  { "$value": "#1A0000", "$type": "color" },
        "20":  { "$value": "#330000", "$type": "color" },
        "30":  { "$value": "#4D0000", "$type": "color" },
        "40":  { "$value": "#660000", "$type": "color" },
        "50":  { "$value": "#800000", "$type": "color" },
        "60":  { "$value": "#990000", "$type": "color" },
        "70":  { "$value": "#B30000", "$type": "color" },
